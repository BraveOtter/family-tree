generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Sex {
  FEMALE
  MALE
  INTERSEX
  UNKNOWN
  OTHER
}

enum DatePrecision {
  EXACT
  MONTH
  YEAR
  DECADE
  BEFORE
  AFTER
  BETWEEN
  ABOUT
  UNKNOWN
}

enum RelationshipType {
  BIOLOGICAL
  ADOPTIVE
  FOSTER
  STEP
  GUARDIAN
  UNKNOWN
}

enum PartnershipType {
  MARRIAGE
  CIVIL_UNION
  DOMESTIC_PARTNERSHIP
  RELATIONSHIP
  UNKNOWN
}

enum EventType {
  BIRTH
  DEATH
  BURIAL
  CREMATION
  RESIDENCE
  OCCUPATION
  EDUCATION
  IMMIGRATION
  EMIGRATION
  MILITARY_SERVICE
  MARRIAGE
  DIVORCE
  SEPARATION
  CUSTOM
}

enum MediaType {
  PROFILE_PHOTO
  PHOTO
  DOCUMENT
  AUDIO
  VIDEO
  OTHER
}

model Tree {
  id           String        @id @default(cuid())
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  people       Person[]
  partnerships Partnership[]
  sources      Source[]
}

model Person {
  id             String        @id @default(cuid())
  treeId         String
  tree           Tree          @relation(fields: [treeId], references: [id], onDelete: Cascade)
  givenNames     String
  surnames       String?
  preferredName  String?
  maidenName     String?
  sex            Sex           @default(UNKNOWN)
  notes          String?
  isLiving       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  events         PersonEvent[]
  media          Media[]
  sourceLinks    PersonSource[]
  parentLinks    ParentChild[] @relation("ChildLinks")
  childLinks     ParentChild[] @relation("ParentLinks")
  partnershipsA  Partnership[] @relation("PartnerA")
  partnershipsB  Partnership[] @relation("PartnerB")

  @@index([treeId, surnames, givenNames])
}

model ParentChild {
  id          String           @id @default(cuid())
  parentId    String
  childId     String
  type        RelationshipType @default(BIOLOGICAL)
  startDateId String?
  endDateId   String?
  notes       String?
  parent      Person           @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child       Person           @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)
  startDate   FlexibleDate?    @relation("ParentStart", fields: [startDateId], references: [id])
  endDate     FlexibleDate?    @relation("ParentEnd", fields: [endDateId], references: [id])

  @@unique([parentId, childId, type])
  @@index([childId])
  @@index([startDateId])
  @@index([endDateId])
}

model Partnership {
  id          String          @id @default(cuid())
  treeId      String
  tree        Tree            @relation(fields: [treeId], references: [id], onDelete: Cascade)
  partnerAId  String
  partnerBId  String
  partnerA    Person          @relation("PartnerA", fields: [partnerAId], references: [id], onDelete: Cascade)
  partnerB    Person          @relation("PartnerB", fields: [partnerBId], references: [id], onDelete: Cascade)
  type        PartnershipType @default(MARRIAGE)
  startDateId String?
  endDateId   String?
  startDate   FlexibleDate?   @relation("PartnershipStart", fields: [startDateId], references: [id])
  endDate     FlexibleDate?   @relation("PartnershipEnd", fields: [endDateId], references: [id])
  startPlace  String?
  endPlace    String?
  notes       String?
  events      PartnershipEvent[]

  @@index([treeId])
  @@index([partnerAId])
  @@index([partnerBId])
  @@index([startDateId])
  @@index([endDateId])
}

model FlexibleDate {
  id                String             @id @default(cuid())
  display           String
  precision         DatePrecision      @default(UNKNOWN)
  year              Int?
  month             Int?
  day               Int?
  endYear           Int?
  endMonth          Int?
  endDay            Int?
  sortValue         Int?
  personEvents      PersonEvent[]
  partnershipEvents PartnershipEvent[]
  parentStarts      ParentChild[]      @relation("ParentStart")
  parentEnds        ParentChild[]      @relation("ParentEnd")
  partnershipStarts Partnership[]      @relation("PartnershipStart")
  partnershipEnds   Partnership[]      @relation("PartnershipEnd")
}

model PersonEvent {
  id          String         @id @default(cuid())
  personId    String
  person      Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  type        EventType
  title       String?
  dateId      String?
  date        FlexibleDate?  @relation(fields: [dateId], references: [id])
  place       String?
  latitude    Float?
  longitude   Float?
  description String?
  sourceLinks EventSource[]

  @@index([personId, type])
  @@index([dateId])
}

model PartnershipEvent {
  id            String        @id @default(cuid())
  partnershipId String
  partnership   Partnership   @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  type          EventType
  title         String?
  dateId        String?
  date          FlexibleDate? @relation(fields: [dateId], references: [id])
  place         String?
  description   String?

  @@index([partnershipId, type])
  @@index([dateId])
}

model Media {
  id          String    @id @default(cuid())
  personId    String
  person      Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  type        MediaType
  path        String
  mimeType    String?
  title       String?
  description String?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([personId, type])
}

model Source {
  id         String         @id @default(cuid())
  treeId     String
  tree       Tree           @relation(fields: [treeId], references: [id], onDelete: Cascade)
  title      String
  author     String?
  repository String?
  citation   String?
  url        String?
  notes      String?
  filePath   String?
  mimeType   String?
  createdAt  DateTime       @default(now())
  people     PersonSource[]
  events     EventSource[]

  @@index([treeId, title])
}

model PersonSource {
  personId String
  sourceId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  note     String?

  @@id([personId, sourceId])
}

model EventSource {
  eventId  String
  sourceId String
  event    PersonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source   Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  note     String?

  @@id([eventId, sourceId])
}

model AppSettings {
  id                    Int      @id @default(1)
  authenticationEnabled Boolean  @default(false)
  passwordHash          String?
  sessionSecret         String?
  updatedAt             DateTime @updatedAt
}
